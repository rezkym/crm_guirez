# ===========================================
# ENVIRONMENT CONFIGURATION
# ===========================================
# Rename file ini menjadi .env untuk mengaktifkan konfigurasi

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=your_password
DB_NAME=mindi_crm
DB_SSL=false
DB_LOGGING=0

# ===========================================
# APPLICATION CONFIGURATION  
# ===========================================
PORT=3000
API_PREFIX=/api
API_VERSION=v1
NODE_ENV=development

# ===========================================
# AUTHENTICATION & SECURITY
# ===========================================
# Token TTL (Time To Live) dalam hari
AUTH_ACCESS_TTL_DAYS=7
AUTH_REFRESH_TTL_DAYS=30
AUTH_LOGOUT_STRATEGY=revoke_session
AUTH_CLEANUP_INTERVAL_MINUTES=60

# Password Security - PBKDF2 iterations untuk hashing
PASSWORD_PBKDF2_ITERATIONS=210000

# ===========================================
# RATE LIMITING CONFIGURATION
# ===========================================
# Window waktu untuk rate limiting dalam menit
RATE_LIMIT_WINDOW_MINUTES=15
# Maksimal percobaan dalam window
RATE_LIMIT_MAX_ATTEMPTS=5
# Durasi lockout setelah melebihi max attempts (menit)
RATE_LIMIT_LOCKOUT_MINUTES=15

# ===========================================
# SESSION & SECURITY
# ===========================================
SESSION_COOKIE_NAME=session_id

# ===========================================
# CORS CONFIGURATION
# ===========================================
# Daftar origin yang diizinkan (pisahkan dengan koma)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
